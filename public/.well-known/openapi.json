{
  "openapi": "3.1.0",
  "info": {
    "title": "YAZIO Meal Logger",
    "description": "Log meals, search foods, and view nutrition summaries via YAZIO.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://your-app.vercel.app"
    }
  ],
  "paths": {
    "/api/tools/log-meal": {
      "post": {
        "operationId": "logMeal",
        "summary": "Log a meal to YAZIO diary",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["date", "mealType", "entries"],
                "properties": {
                  "date": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "description": "Date in YYYY-MM-DD format"
                  },
                  "mealType": {
                    "type": "string",
                    "enum": ["breakfast", "lunch", "dinner", "snack"]
                  },
                  "entries": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 20,
                    "items": {
                      "type": "object",
                      "required": ["name", "quantity", "unit"],
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Food name (German)"
                        },
                        "quantity": {
                          "type": "number",
                          "minimum": 0.1,
                          "maximum": 10000
                        },
                        "unit": {
                          "type": "string",
                          "enum": ["g", "ml", "kg", "l", "stück", "portion", "scheibe", "scoop", "el", "tl", "tasse", "becher"]
                        }
                      }
                    }
                  },
                  "originalText": {
                    "type": "string",
                    "description": "Original user text (optional)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Meal logged successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "matchedProduct": { "type": "string" },
                          "quantity": { "type": "number" },
                          "unit": { "type": "string" },
                          "calories": { "type": "number" },
                          "protein": { "type": "number" },
                          "carbs": { "type": "number" },
                          "fat": { "type": "number" }
                        }
                      }
                    },
                    "totals": {
                      "type": "object",
                      "properties": {
                        "calories": { "type": "number" },
                        "protein": { "type": "number" },
                        "carbs": { "type": "number" },
                        "fat": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/day-summary": {
      "get": {
        "operationId": "getDaySummary",
        "summary": "Get nutrition summary for a day",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Date in YYYY-MM-DD format"
          }
        ],
        "responses": {
          "200": {
            "description": "Day summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "date": { "type": "string" },
                    "meals": {
                      "type": "object",
                      "properties": {
                        "breakfast": { "type": "array", "items": { "$ref": "#/components/schemas/LoggedEntry" } },
                        "lunch": { "type": "array", "items": { "$ref": "#/components/schemas/LoggedEntry" } },
                        "dinner": { "type": "array", "items": { "$ref": "#/components/schemas/LoggedEntry" } },
                        "snack": { "type": "array", "items": { "$ref": "#/components/schemas/LoggedEntry" } }
                      }
                    },
                    "totals": { "$ref": "#/components/schemas/Nutrients" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/delete-entry": {
      "delete": {
        "operationId": "deleteEntry",
        "summary": "Delete a diary entry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["date"],
                "properties": {
                  "date": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "mealType": {
                    "type": "string",
                    "enum": ["breakfast", "lunch", "dinner", "snack"]
                  },
                  "entryName": {
                    "type": "string",
                    "description": "Name of the food to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "deleted": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "mealType": { "type": "string" },
                        "calories": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/search-food": {
      "get": {
        "operationId": "searchFood",
        "summary": "Search for foods in YAZIO database",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Food name to search for (German)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 5, "maximum": 20 },
            "description": "Max results"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string" },
                          "name": { "type": "string" },
                          "brand": { "type": "string" },
                          "calories": { "type": "number" },
                          "protein": { "type": "number" },
                          "carbs": { "type": "number" },
                          "fat": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "status": { "type": "string" },
                    "mode": { "type": "string" },
                    "timestamp": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Nutrients": {
        "type": "object",
        "properties": {
          "calories": { "type": "number" },
          "protein": { "type": "number" },
          "carbs": { "type": "number" },
          "fat": { "type": "number" }
        }
      },
      "LoggedEntry": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "matchedProduct": { "type": "string" },
          "quantity": { "type": "number" },
          "unit": { "type": "string" },
          "calories": { "type": "number" },
          "protein": { "type": "number" },
          "carbs": { "type": "number" },
          "fat": { "type": "number" }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
